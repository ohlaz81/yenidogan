# ---------------------------------------------------------------------------
# Yerel geliştirme (SQLite dosyası — PostgreSQL kurmadan)
# ---------------------------------------------------------------------------
DATABASE_URL="file:./prisma/dev.db"
# Uzak Turso kullanırken (Vercel üretim): örnek
# DATABASE_URL="libsql://xxxx.turso.io"
# LIBSQL_AUTH_TOKEN="turso_..."

# Turso / libSQL uzak veritabanı (DATABASE_URL libsql:// veya https:// ise)
LIBSQL_AUTH_TOKEN=""

# ---------------------------------------------------------------------------
# Auth.js — üretimde mutlaka güçlü değer (örn. openssl rand -base64 32)
# ---------------------------------------------------------------------------
AUTH_SECRET="yerine-guclu-bir-sir-koyun-en-az-32-karakter"
AUTH_TRUST_HOST="true"

# Geliştirme
NEXTAUTH_URL="http://localhost:3000"
# Vercel üretim örneği: https://senin-projen.vercel.app
