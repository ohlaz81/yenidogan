# ---------------------------------------------------------------------------
# Supabase — Project Settings → API
#
# Zorunlu (bu projedeki server Supabase client): URL + service_role
# service_role'ü yalnızca sunucu env'de tutun; repoya / istemciye koymayın.
#
# İsteğe bağlı: Tarayıcıda @supabase/supabase-js + RLS kullanacaksan anon key
# (şu anki kod yolu service_role ile sunucudan çalışıyor; anon zorunlu değil.)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ...service_role-anahtar"

# Tarayıcı / public istemci için (opsiyonel — RLS açık tablolar)
# NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ...anon-anahtar"

# ---------------------------------------------------------------------------
# Auth.js
# ---------------------------------------------------------------------------
AUTH_SECRET="yerine-guclu-bir-sir-koyun-en-az-32-karakter"
AUTH_TRUST_HOST="true"
NEXTAUTH_URL="http://localhost:3000"

# İletişim sayfasında gösterilecek e-posta (opsiyonel)
# NEXT_PUBLIC_CONTACT_EMAIL="ornek@site.com"
