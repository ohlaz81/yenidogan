# ---------------------------------------------------------------------------
# Supabase (Prisma 7) — Settings → Database → Connection string
#
# 1) DATABASE_URL = pool (genelde 6543, "Transaction pooler" / "URI")
#    Sona ?pgbouncer=true ve gerekirse &sslmode=require
#    Node "pg" SSL uyarısını azaltmak için: &uselibpqcompat=true
# 2) DIRECT_URL = migrasyon (doğrudan) — "Direct connection" veya port 5432, pooler değil
#    (pool ile migrasyon hata veya asılı kalabilir)
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres.XXXX:ŞIFRE@aws-0-xxx.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require&uselibpqcompat=true"
DIRECT_URL="postgresql://postgres:ŞIFRE@db.XXXX.supabase.co:5432/postgres?sslmode=require&uselibpqcompat=true"

# Her iki env de (gerekirse aynı) Vercel Production/Preview alanına ekleyin

# Lokalde "self-signed certificate in certificate chain" hatası (proxy/antivirüs) ise:
# DATABASE_SSL_INSECURE=true
# Vercel’de TANIMLAMAYIN.

# ---------------------------------------------------------------------------
# Auth.js
# ---------------------------------------------------------------------------
AUTH_SECRET="yerine-guclu-bir-sir-koyun-en-az-32-karakter"
AUTH_TRUST_HOST="true"
NEXTAUTH_URL="http://localhost:3000"
